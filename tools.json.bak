{
  "tools": [
    {
      "name": "配量配置NTP客户端-Chrony",
      "description": "使用条件：提前在系统中安装chrony包即可。\n使用说明：\n  1.批量配置Linux服务器时间同步。\n  2.支持配置、还原、获取NTP状态等信息。\n  3.支持常见系统，如Redhat、Kylin、Ubuntu等。",
      "module": "ChronyNtp_tool",
      "class": "NTPConfigTool",
      "icon": "🕐"
    },
    {
      "name": "批量用户管理",
      "description": "批量创建、删除Linux系统用户，支持sudo权限配置，支持密码确认校验",
      "module": "linuxAddUser_tool",
      "class": "UserManageGUI",
      "icon": "👤"
    },
    {
      "name": "SSH端口配置",
      "description": "批量修改Linux服务器SSH端口、禁止root远程登录等sshd配置项",
      "module": "ChangeSshPort_tool",
      "class": "SSHPortGUI",
      "icon": "🔐"
    }
  ]
}
